# Google Analytics 4 — Measurement ID from GA4 → Admin → Data streams (format G-xxxxxxxxxx).
# Gatsby only exposes env vars to the client when prefixed with GATSBY_.
#
# Local: create a file named .env.development in the project root (same folder as package.json)
#        with one line: GATSBY_GA_MEASUREMENT_ID=G-xxxxxxxxxx
#        That file is gitignored; it only exists on your machine.
# Production: set GATSBY_GA_MEASUREMENT_ID in Netlify Site settings → Environment variables.
GATSBY_GA_MEASUREMENT_ID=
